# Copy this to .env.local for local development (SQLite file, no setup needed)
TURSO_DATABASE_URL=file:local.db

# Optional: age (ms) after which completed/cancelled tasks auto-archive.
# Defaults to 30 days if unset. Set low (e.g. 60000 = 1 min) to test archiving.
# ARCHIVE_AGE_MS=60000

# For Vercel production deployment, set these in the Vercel dashboard:
# TURSO_DATABASE_URL=libsql://your-db-name.turso.io
# TURSO_AUTH_TOKEN=your-auth-token-here
#
# Setup steps:
#   1. Install Turso CLI: https://docs.turso.tech/cli/introduction
#   2. turso auth login
#   3. turso db create dameon-notes
#   4. turso db show --url dameon-notes   → copy to TURSO_DATABASE_URL
#   5. turso db tokens create dameon-notes → copy to TURSO_AUTH_TOKEN
